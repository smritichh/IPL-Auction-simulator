# Supabase credentials for login + saved history (optional — the app runs as a
# guest-only experience if these are unset). Copy to .env.local and fill in from
# your Supabase project: Dashboard → Project Settings → API.
# .env.local is gitignored (Vite ignores *.local). Set the same two vars in
# Vercel → Project → Settings → Environment Variables for production.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
